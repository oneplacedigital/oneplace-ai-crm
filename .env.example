# ============================================
# ONEPLACE AI CRM - Root environment template
# Copy to .env (root) and apps/*/.env then fill in values
# ============================================

# --- Database (Postgres) ---
DATABASE_URL="postgresql://oneplace:oneplace@localhost:5432/oneplace_crm?schema=public"

# --- API ---
API_PORT=4000
NODE_ENV="development"

# --- Auth (generate with: openssl rand -base64 48) ---
JWT_SECRET="replace-with-48-byte-random-secret"
JWT_REFRESH_SECRET="replace-with-another-48-byte-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# --- At-rest encryption (32 bytes base64, generate: openssl rand -base64 32) ---
ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTES"

# --- Web frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_NAME="ONEPLACE AI CRM"

# --- Meta / Facebook Lead Ads ---
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN="oneplace-verify-token"
META_GRAPH_VERSION="v19.0"
META_TEST_EVENT_CODE=""

# --- WhatsApp Cloud API ---
# Per-tenant phone-number-id + access-token live in DB encrypted; only verify token is global
WHATSAPP_VERIFY_TOKEN="oneplace-wa-verify"

# --- AI ---
OPENAI_API_KEY=""
AI_MODEL="gpt-4o-mini"
AI_ENABLED="false"

# --- CORS ---
CORS_ORIGIN="http://localhost:3000"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
