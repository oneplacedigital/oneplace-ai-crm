NODE_ENV=development
API_PORT=4000

# --- Database ---
DATABASE_URL="postgresql://oneplace:oneplace@localhost:5432/oneplace_crm?schema=public"

# --- Auth ---
JWT_SECRET="replace-with-48-byte-random-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-another-48-byte-random-secret-min-32"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# --- At-rest encryption for tenant integration tokens ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTES_MUST_BE_44_CHARS_AAAA"

# --- CORS / rate limit ---
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Meta Lead Ads + Conversion API ---
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN="oneplace-verify-token"
META_GRAPH_VERSION="v19.0"
META_TEST_EVENT_CODE=""

# --- WhatsApp Cloud API (verify token for webhook subscribe handshake) ---
# Per-tenant phone-number-id + access-token live in the tenants table (encrypted).
WHATSAPP_VERIFY_TOKEN="oneplace-wa-verify"

# --- AI ---
OPENAI_API_KEY=""
AI_MODEL="gpt-4o-mini"
AI_ENABLED="false"
