generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  COUNSELOR
  VIEWER
}

enum TenantPlan {
  TRIAL
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeadSource {
  META_ADS
  GOOGLE_ADS
  ORGANIC_SEARCH
  REFERRAL
  WALK_IN
  WEBSITE_FORM
  WHATSAPP
  PHONE_CALL
  IMPORT
  MANUAL
  OTHER
}

enum ActivityType {
  NOTE
  CALL
  WHATSAPP_SENT
  WHATSAPP_RECEIVED
  EMAIL_SENT
  EMAIL_RECEIVED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  STATUS_CHANGE
  ASSIGNMENT_CHANGE
  PAYMENT_LOGGED
  AI_SUGGESTION
  META_EVENT_SENT
  SYSTEM
}

enum CoursePace {
  WEEKDAY
  WEEKEND
  EVENING
  ONLINE
  HYBRID
}

enum WebhookProvider {
  META_LEAD_ADS
  META_CONVERSIONS
  WHATSAPP_CLOUD
  RESEND
  OTHER
}

enum WorkflowTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_NO_RESPONSE_24H
  LEAD_ASSIGNED
}

enum WorkflowActionType {
  SEND_WHATSAPP_TEMPLATE
  SEND_EMAIL
  START_EMAIL_SEQUENCE
  ASSIGN_COUNSELOR
  SET_FOLLOWUP
  SET_STATUS
  SEND_META_EVENT
  NOTIFY_COUNSELOR
}

enum WorkflowRunStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

enum LicenseStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REVOKED
}

enum EmailSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

// --- LICENSE / SUBSCRIPTION ----------------------------------------------

model LicenseKey {
  id              String         @id @default(cuid())
  code            String         @unique
  name            String?
  plan            TenantPlan     @default(TRIAL)
  status          LicenseStatus  @default(ACTIVE)
  validForDays    Int            @default(30)
  maxRedemptions  Int            @default(1)
  redeemedCount   Int            @default(0)
  notes           String?
  createdAt       DateTime       @default(now())
  expiresAt       DateTime?
  redeemedTenants Tenant[]

  @@index([code])
  @@index([status])
  @@map("license_keys")
}

// --- CORE MODELS ---------------------------------------------------------

model Tenant {
  id              String      @id @default(cuid())
  slug            String      @unique
  name            String
  email           String      @unique
  phone           String?
  city            String?     @default("Nashik")
  country         String?     @default("IN")
  plan            TenantPlan  @default(TRIAL)
  isActive        Boolean     @default(true)
  isSuspended     Boolean     @default(false)
  suspendedReason String?
  approvalStatus  ApprovalStatus @default(PENDING)
  rejectedReason  String?

  licenseKeyId     String?
  licenseExpiresAt DateTime?

  metaPixelId     String?
  metaAccessToken String?     @db.Text
  metaAdAccountId String?

  whatsappPhoneId String?
  whatsappBizId   String?
  whatsappToken   String?     @db.Text

  emailFromAddress String?    @default("noreply@pipely.in")
  emailFromName    String?    @default("Pipely")
  emailReplyTo     String?

  brandColor      String?     @default("#6366F1")
  logoUrl         String?
  timezone        String      @default("Asia/Kolkata")

  trialEndsAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  licenseKey      LicenseKey? @relation(fields: [licenseKeyId], references: [id])
  users           User[]
  leads           Lead[]
  activities      LeadActivity[]
  courses         Course[]
  auditLogs       AuditLog[]
  workflows       Workflow[]
  workflowRuns    WorkflowRun[]
  emailTemplates  EmailTemplate[]
  emailSends      EmailSend[]
  emailSequences  EmailSequence[]
  customFieldDefs CustomFieldDefinition[]

  @@index([slug])
  @@index([licenseKeyId])
  @@map("tenants")
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  phone         String?
  name          String
  passwordHash  String
  role          UserRole  @default(COUNSELOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedLeads Lead[]    @relation("AssignedCounselor")
  activities    LeadActivity[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Course {
  id            String     @id @default(cuid())
  tenantId      String
  name          String
  code          String?
  description   String?    @db.Text
  durationWeeks Int        @default(12)
  feeInr        Int        @default(0)
  pace          CoursePace @default(WEEKDAY)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads         Lead[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("courses")
}

model Lead {
  id              String      @id @default(cuid())
  tenantId        String

  fullName        String
  email           String?
  phone           String
  whatsapp        String?
  city            String?     @default("Nashik")

  status          LeadStatus  @default(NEW)
  source          LeadSource  @default(MANUAL)
  sourceDetail    String?
  score           Int         @default(0)
  priority        Int         @default(2)

  assignedToId    String?

  courseId        String?
  budgetInr       Int?
  expectedJoinAt  DateTime?

  metaLeadId      String?     @unique
  metaCampaignId  String?
  metaAdsetId     String?
  metaAdId        String?
  fbclid          String?
  metaEventLastSent DateTime?
  metaEventLastStatus String?

  aiSummary       String?     @db.Text
  aiNextAction    String?     @db.Text
  aiUpdatedAt     DateTime?

  notes           String?     @db.Text
  tags            String[]    @default([])

  unsubscribedAt  DateTime?

  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  convertedAt     DateTime?
  lostReason      String?
  customFields    Json        @default("{}")

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo      User?       @relation("AssignedCounselor", fields: [assignedToId], references: [id], onDelete: SetNull)
  course          Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  activities      LeadActivity[]
  workflowRuns    WorkflowRun[]
  emailSends      EmailSend[]
  sequenceEnrollments EmailSequenceEnrollment[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, source])
  @@index([tenantId, nextFollowUpAt])
  @@index([tenantId, createdAt])
  @@map("leads")
}

model LeadActivity {
  id          String       @id @default(cuid())
  tenantId    String
  leadId      String
  userId      String?
  type        ActivityType
  title       String
  body        String?      @db.Text
  metadata    Json?
  createdAt   DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([leadId, createdAt])
  @@index([tenantId, type])
  @@map("lead_activities")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  entity      String
  entityId    String
  action      String
  diff        Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model WebhookEvent {
  id          String           @id @default(cuid())
  provider    WebhookProvider
  externalId  String
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime         @default(now())

  @@unique([provider, externalId])
  @@index([createdAt])
  @@map("webhook_events")
}

model Workflow {
  id              String          @id @default(cuid())
  tenantId        String
  name            String
  isActive        Boolean         @default(true)
  trigger         WorkflowTrigger
  triggerStatuses LeadStatus[]    @default([])
  actions         Json
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs            WorkflowRun[]

  @@index([tenantId])
  @@index([tenantId, trigger, isActive])
  @@map("workflows")
}

model WorkflowRun {
  id          String            @id @default(cuid())
  tenantId    String
  workflowId  String
  leadId      String?
  status      WorkflowRunStatus @default(PENDING)
  result      Json?
  error       String?
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow    Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  lead        Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([workflowId])
  @@index([leadId])
  @@index([tenantId, status])
  @@map("workflow_runs")
}

// --- EMAIL AUTOMATION ----------------------------------------------------

model EmailTemplate {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  subject     String
  bodyHtml    String       @db.Text
  bodyText    String?      @db.Text
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sends       EmailSend[]
  sequenceSteps EmailSequenceStep[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("email_templates")
}

model EmailSend {
  id            String          @id @default(cuid())
  tenantId      String
  leadId        String?
  templateId    String?
  toEmail       String
  fromEmail     String
  subject       String
  bodyHtml      String          @db.Text
  status        EmailSendStatus @default(QUEUED)
  providerId    String?
  errorMessage  String?
  scheduledFor  DateTime?
  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  metadata      Json?
  createdAt     DateTime        @default(now())

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead          Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  template      EmailTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([leadId])
  @@index([scheduledFor])
  @@map("email_sends")
}

model EmailSequence {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps       EmailSequenceStep[]
  enrollments EmailSequenceEnrollment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("email_sequences")
}

model EmailSequenceStep {
  id          String          @id @default(cuid())
  sequenceId  String
  templateId  String
  delayHours  Int             @default(24)
  order       Int

  sequence    EmailSequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template    EmailTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([sequenceId, order])
  @@index([sequenceId])
  @@map("email_sequence_steps")
}

model EmailSequenceEnrollment {
  id          String          @id @default(cuid())
  sequenceId  String
  leadId      String
  currentStep Int             @default(0)
  isActive    Boolean         @default(true)
  enrolledAt  DateTime        @default(now())
  completedAt DateTime?

  sequence    EmailSequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead        Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([leadId])
  @@index([isActive, currentStep])
  @@map("email_sequence_enrollments")
}

// --- CUSTOM FIELDS -------------------------------------------------------

model CustomFieldDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  entityType  String   @default("LEAD")
  key         String
  label       String
  type        String   // TEXT, TEXTAREA, NUMBER, DATE, SELECT, BOOLEAN, URL, EMAIL
  required    Boolean  @default(false)
  options     Json?
  placeholder String?
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, key])
  @@index([tenantId, entityType, isActive])
  @@map("custom_field_definitions")
}
